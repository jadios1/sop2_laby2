// wazne

//parent
int shm_fd;
int shm_size = keyboard_count * key_count * sizeof(double);
if ((shm_fd = shm_open(SHARED_MEM_NAME, O_CREAT | O_EXCL | O_RDWR, 0666)) == -1) {
    ERR("shm_open");
}
if (ftruncate(shm_fd, shm_size) == -1) {
    ERR("ftruncate");
}

double* shm_ptr;
if ((shm_ptr = mmap(NULL, shm_size, PROT_READ | PROT_WRITE, MAP_SHARED, shm_fd, 0)) == MAP_FAILED) {
    ERR("mmap");
}


// children, nie ma: ftruncate, O_CREAT | O_EXCL
int shm_fd;
int shm_size = keyboard_count * key_count * sizeof(double);
if ((shm_fd = shm_open(SHARED_MEM_NAME, O_RDWR, 0666)) == -1) {
    ERR("shm_open");
}

// to samo co w parent
double* shm_ptr;
if ((shm_ptr = mmap(NULL, shm_size, PROT_READ | PROT_WRITE, MAP_SHARED, shm_fd, 0)) == MAP_FAILED) {
    ERR("mmap");
}
