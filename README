tutaj wazne rzeczy:

//TWORZENIE SHARED MUTEX :D   PAMIETAJ ZEBY DESTROY I ATRYBUTY TEZ DESTROY

typedef struct {
    pthread_mutex_t mutex;
} shared_t;


//dawanie atrybutow (skopiuj to cale pp) ;p
shared_t *sh = mmap(NULL, sizeof(shared_t),PROT_READ | PROT_WRITE,MAP_SHARED | MAP_ANONYMOUS,-1, 0);
pthread_mutexattr_t attr;
pthread_mutexattr_init(&attr);
pthread_mutexattr_setpshared(&attr, PTHREAD_PROCESS_SHARED);
pthread_mutexattr_setrobust(&attr, PTHREAD_MUTEX_ROBUST);

// init mutexa
pthread_mutex_init(&sh->mutex, &attr);

//UZYCIE

int err = pthread_mutex_lock(&sh->mutex);

//to dajesz jak chcesz sprawdzic czy proces ktory rozpoczal ten mutex umarl ;p
if (err == EOWNERDEAD) {
    printf("poprzedni proces umarl\n");
    pthread_mutex_consistent(&sh->mutex);
}

pthread_mutex_unlock(&sh->mutex);




//TWORZENIE SHARED BAREIRY

typedef struct {
    pthread_barrier_t barrier;
} shared_t;


shared_t *sh = mmap(...);

pthread_barrierattr_t attr;
pthread_barrierattr_init(&attr);
pthread_barrierattr_setpshared(&attr, PTHREAD_PROCESS_SHARED);

// 3 procesy tutaj no wiadomo mozna dac ilekolwiek
pthread_barrier_init(&sh->barrier, &attr, 3);

//uzycie

printf("before barrier\n");

pthread_barrier_wait(&sh->barrier);

printf("after barrier\n");

//POZNIEJ PAMIETAJ

pthread_barrier_destroy()
pthread_barrierattr_destroy()






//shared memory object

int fd = shm_open("/my_mem", O_CREAT | O_RDWR, 0666);
ftruncate(fd, 1024);

char *mem = mmap(NULL, 1024, PROT_READ | PROT_WRITE, MAP_SHARED, fd, 0);

//USUWANIE TEGO
shm_unlink("/my_mem");









//MMAP BEZ PLIKU

void *ptr = mmap(NULL, SIZE,
                 PROT_READ | PROT_WRITE,
                 MAP_SHARED | MAP_ANONYMOUS,
                 -1, 0);

//UZYCIE

int *arr = mmap(...);
arr[0] = 10;


//MMAP Z PLIKIEM

int fd = open("file.txt", O_RDONLY);

struct stat st;
fstat(fd, &st);
size_t size = st.st_size;

char *data = mmap(NULL, size,
                  PROT_READ,
                  MAP_PRIVATE,
                  fd, 0);

//ZAMYKANIE
close(fd);

//CZYTANIE
printf("%c\n", data[0]);
printf("%c\n", data[10]);

//LUB
for (int i = 0; i < size; i++) {
    putchar(data[i]);
}


//PISANIE
//DZIALA TYLKO JAK      mmap(NULL, size,PROT_READ | PROT_WRITE,MAP_SHARED,fd, 0);

data[0] = 'A';

//TUTAJ SPRAWDZANIE CRASHA

int status;
int crashed = 0;

for (int i = 0; i < N; i++) {
    wait(&status);

    if (!WIFEXITED(status)) {
        crashed = 1;
    }
}

if (crashed) {
    printf("FAIL\n");
} else {
    printf("OK + wyniki\n");
}







//przykladowy kod

typedef struct {
    pthread_barrier_t barrier;
} shared_t;

int main() {
    shared_t *sh = mmap(NULL, sizeof(shared_t),
                        PROT_READ | PROT_WRITE,
                        MAP_SHARED | MAP_ANONYMOUS,
                        -1, 0);

    pthread_barrierattr_t attr;
    pthread_barrierattr_init(&attr);
    pthread_barrierattr_setpshared(&attr, PTHREAD_PROCESS_SHARED);

    pthread_barrier_init(&sh->barrier, &attr, 3);

    for (int i = 0; i < 2; i++) {
        if (fork() == 0) {
            printf("child before\n");
            pthread_barrier_wait(&sh->barrier);
            printf("child after\n");
            exit(0);
        }
    }

    printf("parent before\n");
    pthread_barrier_wait(&sh->barrier);
    printf("parent after\n");

    while (wait(NULL) > 0);
}


